# Bigdata API (required)
BIGDATA_API_KEY=your-api-key

# Optional: API base URL (default: https://api.bigdata.com)
# BIGDATA_API_BASE_URL=https://api.bigdata.com

# Optional: rate limit and polling (must match your API limits)
# BIGDATA_RATE_LIMIT_PER_MINUTE=500
# BIGDATA_RATE_LIMIT_SAFETY_MARGIN=20
# BIGDATA_POLL_INTERVAL_SEC=10
# BIGDATA_UPLOAD_MAX_RETRIES=5
